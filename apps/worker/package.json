{
  "name": "worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:prod": "node --import tsx src/index.ts",
    "start:render": "node --import tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@octokit/auth-app": "^8.2.0",
    "@repo/analysis": "workspace:*",
    "@repo/db": "workspace:*",
    "@repo/providers": "workspace:*",
    "@repo/queue": "workspace:*",
    "@repo/review": "workspace:*",
    "@repo/shared": "workspace:*",
    "bullmq": "^5.56.0",
    "dotenv": "^16.4.7",
    "ioredis": "^5.4.1",
    "octokit": "^5.0.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
